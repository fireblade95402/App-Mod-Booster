@page
@model ExpenseManagement.Pages.ApproveExpensesModel
@{
    ViewData["Title"] = "Approve Expenses";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .error-bar {
            background-color: #dc3545;
            color: white;
            padding: 15px 20px;
            margin-bottom: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .success-bar {
            background-color: #28a745;
            color: white;
            padding: 15px 20px;
            margin-bottom: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            margin-bottom: 30px;
        }

        .header h1 {
            color: #667eea;
            font-size: 32px;
            margin-bottom: 10px;
        }

        .back-link {
            display: inline-block;
            color: #667eea;
            text-decoration: none;
            margin-bottom: 15px;
            font-size: 14px;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        .manager-select {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            margin-bottom: 20px;
        }

        .manager-select label {
            display: block;
            margin-bottom: 10px;
            color: #333;
            font-weight: 600;
            font-size: 14px;
        }

        .manager-select select {
            padding: 10px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            min-width: 250px;
        }

        .table-container {
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px;
            text-align: left;
            font-weight: 600;
            font-size: 14px;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid #e0e0e0;
            font-size: 14px;
        }

        tr:hover {
            background-color: #f5f5f5;
        }

        .amount {
            font-weight: 600;
            color: #667eea;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
        }

        .approve-btn, .reject-btn {
            padding: 8px 20px;
            border: none;
            border-radius: 6px;
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.3s ease;
        }

        .approve-btn {
            background-color: #28a745;
            color: white;
        }

        .reject-btn {
            background-color: #dc3545;
            color: white;
        }

        .approve-btn:hover, .reject-btn:hover {
            opacity: 0.85;
        }

        .no-data {
            text-align: center;
            padding: 40px;
            color: #666;
            font-size: 16px;
        }
    </style>
</head>
<body>
    <div class="container">
        @if (Model.HasError)
        {
            <div class="error-bar">
                <h3>⚠️ @Model.ErrorMessage</h3>
                <pre>@Model.ErrorDetails</pre>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="success-bar">
                <h3>✓ @Model.SuccessMessage</h3>
            </div>
        }

        <div class="header">
            <a href="/Index" class="back-link">← Back to Home</a>
            <h1>✅ Approve Expenses</h1>
            <p>Pending expenses awaiting manager approval</p>
        </div>

        <div class="manager-select">
            <label for="ManagerSelect">Approving as Manager:</label>
            <select id="ManagerSelect" asp-items="Model.Users">
            </select>
        </div>

        <div class="table-container">
            @if (Model.PendingExpenses.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Employee</th>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>Submitted</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in Model.PendingExpenses)
                        {
                            <tr>
                                <td>@expense.ExpenseDate.ToString("dd/MM/yyyy")</td>
                                <td>@expense.UserName</td>
                                <td>@expense.CategoryName</td>
                                <td class="amount">£@expense.AmountGBP.ToString("N2")</td>
                                <td>@(expense.Description ?? "-")</td>
                                <td>@(expense.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                <td>
                                    <div class="action-buttons">
                                        <form method="post" asp-page-handler="Approve" style="display: inline;">
                                            <input type="hidden" name="expenseId" value="@expense.ExpenseId" />
                                            <input type="hidden" name="managerId" id="approveManagerId_@expense.ExpenseId" />
                                            <button type="submit" class="approve-btn" 
                                                    onclick="document.getElementById('approveManagerId_@expense.ExpenseId').value = document.getElementById('ManagerSelect').value;">
                                                Approve
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="Reject" style="display: inline;">
                                            <input type="hidden" name="expenseId" value="@expense.ExpenseId" />
                                            <input type="hidden" name="managerId" id="rejectManagerId_@expense.ExpenseId" />
                                            <button type="submit" class="reject-btn"
                                                    onclick="document.getElementById('rejectManagerId_@expense.ExpenseId').value = document.getElementById('ManagerSelect').value;">
                                                Reject
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="no-data">
                    <p>🎉 No pending expenses to approve!</p>
                </div>
            }
        </div>
    </div>
</body>
</html>
